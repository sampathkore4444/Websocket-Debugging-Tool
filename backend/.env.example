# Database Configuration (PostgreSQL)
# Either use DATABASE_URL or individual settings

# Full connection URL (recommended for Docker)
DATABASE_URL=postgres://wsinspect:wsinspect_password@localhost:5432/wsinspect_db?sslmode=disable

# Individual settings (for local development without DATABASE_URL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=wsinspect
DB_PASSWORD=wsinspect_password
DB_NAME=wsinspect_db
DB_SSLMODE=disable

# Server Configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# Proxy Configuration
PROXY_TARGET=ws://localhost:3000
PROXY_BUFFER_SIZE=8192

# Session Configuration
SESSION_RETENTION_DAYS=30

# Logging
LOG_LEVEL=info
